.DS_Store
.env
.env.*
!.env.example

# local build/test output
bin/
dist/
tmp/
.garden/
reports/investigation/

# secrets and local credentials
*.sops.yaml
!.sops.yaml
!secrets/*.sops.yaml
*.agekey
*.key
*.pem
kubeconfig*
secrets/age/key.txt
secrets/*.local.yaml
secrets/*.decrypted.yaml
secrets/argocd-repo-creds.yaml

# Terraform/OpenTofu and hcloud lab artifacts
.terraform/
**/.terraform/
*.tfstate
*.tfstate.*
*.tfplan
terraform.tfvars
*.auto.tfvars
!.tfvars.example
infra/hcloud-lab/generated/
infra/hcloud-lab/kubeconfig*
infra/hcloud-lab/talosconfig*
infra/hcloud-lab/*.secret
infra/hcloud-lab/*.secrets
