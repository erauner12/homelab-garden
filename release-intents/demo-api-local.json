    "revision": "main"
  },
  "manifest": {
    "path": "k8s/targets/local"
  },
  "image": {
    "reference": "registry.example.invalid/demo-api:0.1.0@sha256:1111111111111111111111111111111111111111111111111111111111111111",
    "identityMode": "digest"
