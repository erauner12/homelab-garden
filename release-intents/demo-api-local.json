{
  "schemaVersion": "homelab-garden.release-intent/v1alpha1",
  "kind": "ReleaseIntent",
  "metadata": {
    "name": "demo-api-local"
  },
  "app": {
    "id": "demo-api"
  },
  "environment": "local",
